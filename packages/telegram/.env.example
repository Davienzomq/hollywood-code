# Telegram bot token from @BotFather
HOLLYWOOD_TG_TOKEN=123456:ABC-your-bot-token

# Comma-separated Telegram numeric user IDs allowed to use the bot.
HOLLYWOOD_TG_ALLOWED_IDS=123456789

# Optional: project directory the agent works in (defaults to cwd).
HOLLYWOOD_TG_DIRECTORY=C:\path\to\your\project

# Optional: explicit model in provider/id format (defaults to server config).
HOLLYWOOD_TG_MODEL=anthropic/claude-sonnet-4-5
