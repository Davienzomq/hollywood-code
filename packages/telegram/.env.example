# Telegram bot token from @BotFather
HOLLYWOOD_TG_TOKEN=123456:ABC-your-bot-token

# Comma-separated Telegram numeric user IDs allowed to use the bot.
# Get yours by messaging @userinfobot. Everyone else is silently ignored.
HOLLYWOOD_TG_ALLOWED_IDS=123456789

# Optional: project directory the agent works in (defaults to the cwd where
# you start the bridge).
# HOLLYWOOD_TG_DIRECTORY=C:\path\to\your\project
